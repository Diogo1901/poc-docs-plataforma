---
import Default from '@astrojs/starlight/components/Footer.astro';
const PROJECT_ID = import.meta.env.PUBLIC_PROJECT_ID || "default";
const RAG_API_URL = import.meta.env.PUBLIC_RAG_API_URL || "http://localhost:3001";
---

<Default><slot /></Default>

<div id="chatbot-container">
  <button id="chatbot-toggle" aria-label="Abrir assistente">
    🤖
  </button>

  <div id="chatbot-window" class="hidden">
    <div id="chatbot-header">
      <span>Assistente DevScope</span>
      <button id="chatbot-close">✕</button>
    </div>

    <div id="chatbot-messages">
      <div class="message bot">
        Olá! Sou o assistente de documentação. Como posso ajudar?
      </div>
    </div>

    <div id="chatbot-input-area">
      <input
        id="chatbot-input"
        type="text"
        placeholder="Faz uma pergunta..."
        autocomplete="off"
      />
      <button id="chatbot-send">Enviar</button>
    </div>
  </div>
</div>

<style>
  #chatbot-container {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 1000;
    font-family: var(--sl-font);
  }

  #chatbot-toggle {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--sl-color-accent);
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  #chatbot-window {
    width: 340px;
    height: 480px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    margin-bottom: 0.75rem;
  }

  #chatbot-window.hidden {
    display: none;
  }

  #chatbot-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--sl-color-text);
  }

  #chatbot-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--sl-color-gray-3);
  }

  #chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .message {
    max-width: 85%;
    padding: 0.6rem 0.9rem;
    border-radius: 10px;
    font-size: 0.875rem;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  .message.bot {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text);
    align-self: flex-start;
  }

  .message.user {
    background: var(--sl-color-accent);
    color: white;
    align-self: flex-end;
  }

  .message.loading {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    align-self: flex-start;
    font-style: italic;
  }

  #chatbot-input-area {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  #chatbot-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-size: 0.875rem;
  }

  #chatbot-send {
    padding: 0.5rem 0.9rem;
    background: var(--sl-color-accent);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.875rem;
  }

  #chatbot-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script define:vars={{ PROJECT_ID, RAG_API_URL }}>
  const toggle = document.getElementById("chatbot-toggle");
  const window_ = document.getElementById("chatbot-window");
  const closeBtn = document.getElementById("chatbot-close");
  const input = document.getElementById("chatbot-input");
  const sendBtn = document.getElementById("chatbot-send");
  const messages = document.getElementById("chatbot-messages");

  toggle.addEventListener("click", () => {
    window_.classList.toggle("hidden");
    toggle.style.display = window_.classList.contains("hidden") ? "flex" : "none";
    if (!window_.classList.contains("hidden")) input.focus();
  });

  closeBtn.addEventListener("click", () => {
    window_.classList.add("hidden");
    toggle.style.display = "flex";
  });

  function addMessage(text, type) {
    const msg = document.createElement("div");
    msg.className = `message ${type}`;
    msg.textContent = text;
    messages.appendChild(msg);
    messages.scrollTop = messages.scrollHeight;
    return msg;
  }

  async function sendMessage() {
    const query = input.value.trim();
    if (!query) return;

    input.value = "";
    sendBtn.disabled = true;
    addMessage(query, "user");
    const loading = addMessage("A pensar...", "loading");

    try {
      const res = await fetch(`${RAG_API_URL}/ask`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query, project: PROJECT_ID }),
      });

      const data = await res.json();
      loading.remove();
      addMessage(data.answer || "Erro ao obter resposta.", "bot");
    } catch {
      loading.remove();
      addMessage("Não foi possível contactar o assistente. Tenta novamente.", "bot");
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  }

  sendBtn.addEventListener("click", sendMessage);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") sendMessage();
  });
</script>